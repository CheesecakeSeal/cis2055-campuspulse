@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-header bg-danger text-white p-4">
                    <h1 class="fw-bold mb-0">Access Denied</h1>
                </div>

                <div class="card-body p-5">
                    <p class="text-muted mb-4">
                        You are signed in, but you do not have permission to access this page or perform this action.
                    </p>

                    <a asp-controller="Home" asp-action="Index" class="btn btn-danger">
                        Return to Home
                    </a>

                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary">
                        Browse Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>