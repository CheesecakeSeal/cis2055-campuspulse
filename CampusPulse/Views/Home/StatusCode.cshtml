@{
    var statusCode = ViewData["StatusCode"] as int? ?? Context.Response.StatusCode;

    ViewData["Title"] = statusCode switch
    {
        404 => "Page Not Found",
        403 => "Access Denied",
        _ => "Something Went Wrong"
    };

    var heading = statusCode switch
    {
        404 => "Page not found",
        403 => "Access denied",
        _ => "Something went wrong"
    };

    var message = statusCode switch
    {
        404 => "The page you are looking for does not exist, may have been moved, or may no longer be available.",
        403 => "You do not have permission to access this page.",
        _ => "An unexpected error occurred while processing your request."
    };
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 text-center">
                <div class="card-header text-white p-4" style="background-color: #002147;">
                    <h1 class="display-5 fw-bold mb-0">@statusCode</h1>
                </div>

                <div class="card-body p-5">
                    <h2 class="fw-bold mb-3">@heading</h2>

                    <p class="text-muted mb-4">
                        @message
                    </p>

                    <a asp-controller="Home" asp-action="Index" class="btn text-white" style="background-color: #002147;">
                        Return to Home
                    </a>

                    <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-secondary">
                        Browse Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>