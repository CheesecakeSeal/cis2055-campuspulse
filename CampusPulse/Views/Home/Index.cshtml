@model IEnumerable<CampusPulse.Models.Report>
<div class="container mt-4">
    <div class="hero text-center text-white p-5 rounded-3 mb-4" style="background-color: #002147;">
        <h1 class="fw-bold">CampusPulse</h1>
        <p class="mb-0">Report issues impacting safety and accessibility on campus</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <h3 class="mb-4">Trending Issues</h3>

            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    //Logic to pick the concise class name
                    string sClass = item.Status switch
                    {
                        "Open" => "s-open",
                        "Being Investigated" => "s-invest",
                        "Resolved" => "s-done",
                        "No Action Required" => "s-none",
                        _ => ""
                    };

                    <div class="issue-card shadow-sm p-3 mb-3 bg-white rounded-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="fw-bold mb-1">@item.Title</h5>
                            <span class="s-badge @sClass">@item.Status</span>
                        </div>
                        
                        <p class="text-muted small mb-2">@item.Location / @item.Category</p>
                        <p class="mb-3">@item.Description</p>
                        
                        <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                            <span class="fw-bold" style="color: #002147;">@item.Upvotes Upvotes</span>
                            <a asp-controller="Reports" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary"> View Pulse → </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light border shadow-sm">
                    No reports filed yet.
                </div>
            }
        </div>
    </div>
</div>