@model CampusPulse.Models.ViewModels.ReportDetailsViewModel

@{
    ViewData["Title"] = "Report Details";
}

@functions {
    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Open" => "status-open",
            "Being Investigated" => "status-being-investigated",
            "Resolved" => "status-resolved",
            "No Action Required" => "status-no-action-required",
            _ => "bg-secondary"
        };
    }
}

<div class="page-shell">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary">
            ← Back to Reports
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-campus">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h2 class="mb-1">@Model.Report.Title</h2>
                    <p class="mb-0 opacity-75">
                        @Model.Report.Location / @Model.Report.Category
                    </p>
                </div>

                <span class="badge @GetStatusClass(Model.Report.Status)">
                    @Model.Report.Status
                </span>
            </div>
        </div>

        <div class="card-body">
            <div class="details-grid">
                <div class="detail-row">
                    <div class="detail-label">Category</div>
                    <div class="detail-value">@Model.Report.Category</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Location</div>
                    <div class="detail-value">@Model.Report.Location</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Date Reported</div>
                    <div class="detail-value">@Model.Report.Date_Reported.ToString("dd MMM yyyy HH:mm")</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Observed</div>
                    <div class="detail-value">@Model.Report.Time_Observed.ToString("dd MMM yyyy HH:mm")</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Upvotes</div>
                    <div class="detail-value fw-bold text-campus">@Model.Report.Upvotes</div>
                </div>

                <div class="detail-row">
                    <div class="detail-label">Reporter</div>
                    <div class="detail-value">
                        @(Model.Report.Reporter?.DisplayName ?? "Deleted user")
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Report.ReporterPhone))
                {
                    <div class="detail-row">
                        <div class="detail-label">Reporter Phone</div>
                        <div class="detail-value">@Model.Report.ReporterPhone</div>
                    </div>
                }
            </div>

            @if (Model.IsAuthenticated && !Model.IsOwner && !Model.IsInvestigator)
            {
                <form asp-action="Upvote" asp-route-id="@Model.Report.Id" method="post" class="mt-4">
                    @Html.AntiForgeryToken()

                    @if (Model.HasUpvoted)
                    {
                        <button type="submit" class="btn btn-outline-danger">
                            Remove Upvote
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary">
                            Upvote this report
                        </button>
                    }
                </form>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h4 class="mb-0">Description</h4>
        </div>

        <div class="card-body">
            <p class="mb-0">@Model.Report.Description</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Report.ImageUrl))
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h4 class="mb-0">Attached Image</h4>
            </div>

            <div class="card-body text-center">
                <img src="@Model.Report.ImageUrl"
                     alt="Report image"
                     class="img-fluid rounded border"
                     style="max-height: 500px; object-fit: contain;" />
            </div>
        </div>
    }

    @if (Model.Report.Investigation != null)
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h4 class="mb-0">Investigation Update</h4>
            </div>

            <div class="card-body">
                <div class="details-grid">
                    <div class="detail-row">
                        <div class="detail-label">Actions Taken</div>
                        <div class="detail-value">@Model.Report.Investigation.ActionTaken</div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-label">Date of Action</div>
                        <div class="detail-value">@Model.Report.Investigation.ActionDate.ToString("dd MMM yyyy HH:mm")</div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-label">Investigator</div>
                        <div class="detail-value">
                            @(Model.Report.Investigation.Investigator?.DisplayName ?? "Deleted investigator")
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Report.Investigation.InvestigatorPhone))
                    {
                        <div class="detail-row">
                            <div class="detail-label">Investigator Phone</div>
                            <div class="detail-value">@Model.Report.Investigation.InvestigatorPhone</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No investigation update has been added yet.
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-light">
            <h4 class="mb-0">Activity Timeline</h4>
        </div>

        <div class="card-body">
            @if (Model.Report.Activities != null && Model.Report.Activities.Any())
            {
                @foreach (var activity in Model.Report.Activities.OrderByDescending(a => a.CreatedAtUtc))
                {
                    <div class="timeline-item">
                        <div class="d-flex justify-content-between gap-3 flex-wrap">
                            <div class="timeline-title">@activity.ActionType</div>
                            <div class="timeline-meta">
                                @activity.CreatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </div>
                        </div>

                        <div>@activity.Description</div>

                        <div class="timeline-meta">
                            By @activity.ActorDisplayName
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted mb-0">
                    No activity has been recorded for this report yet.
                </p>
            }
        </div>
    </div>

    @if (!Model.IsAuthenticated)
    {
        <div class="alert alert-warning">
            Please log in to upvote or manage reports.
        </div>
    }

    @if (Model.IsOwner && !Model.IsInvestigator)
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h4 class="mb-0">Reporter Actions</h4>
            </div>

            <div class="card-body">
                <p class="text-muted">
                    You submitted this report. You can edit or delete it below.
                </p>

                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Edit" asp-route-id="@Model.Report.Id" class="btn btn-warning">
                        Edit Report
                    </a>

                    <a asp-action="Delete" asp-route-id="@Model.Report.Id" class="btn btn-danger">
                        Delete Report
                    </a>
                </div>
            </div>
        </div>
    }

    @if (Model.IsInvestigator)
    {
        <div class="card mb-4">
            <div class="card-header bg-campus">
                <h4 class="mb-0">Investigator Actions</h4>
            </div>

            <div class="card-body">
                <form asp-action="UpdateStatus" asp-route-id="@Model.Report.Id" method="post" class="mb-4">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Update Report Status</label>
                        <select name="status" class="form-select">
                            @foreach (var status in Model.StatusOptions)
                            {
                                if (status == Model.Report.Status)
                                {
                                    <option value="@status" selected>@status</option>
                                }
                                else
                                {
                                    <option value="@status">@status</option>
                                }
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-campus">
                        Save Status
                    </button>
                </form>

                <hr />

                <form asp-action="SaveInvestigation" asp-route-id="@Model.Report.Id" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Actions Taken</label>
                        <textarea name="actionTaken" class="form-control" rows="5">@Model.Report.Investigation?.ActionTaken</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Optional Investigator Phone</label>
                        <input name="investigatorPhone"
                               class="form-control"
                               value="@Model.Report.Investigation?.InvestigatorPhone" />
                    </div>

                    <button type="submit" class="btn btn-success">
                        Save Investigation
                    </button>
                </form>
            </div>
        </div>
    }
</div>