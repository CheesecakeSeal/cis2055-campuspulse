@model IEnumerable<CampusPulse.Models.Report>

@{
    ViewData["Title"] = "Reports";

    var currentCategory = ViewData["CurrentCategory"]?.ToString();
    var currentStatus = ViewData["CurrentStatus"]?.ToString();
}

@functions {
    private string GetStatusClass(string? status)
    {
        return status switch
        {
            "Open" => "status-open",
            "Being Investigated" => "status-being-investigated",
            "Resolved" => "status-resolved",
            "No Action Required" => "status-no-action-required",
            _ => "bg-secondary"
        };
    }
}

<div class="page-shell">
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div>
            <h1 class="page-title mb-1">Submitted Reports</h1>
            <p class="page-subtitle mb-0">
                Browse, filter, and review reported campus issues.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-campus">
            Submit New Report
        </a>
    </div>

    <form asp-action="Index" method="get" class="surface p-4 mb-4">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Search Title</label>
                <input type="text"
                       name="searchString"
                       value="@ViewData["CurrentFilter"]"
                       class="form-control"
                       placeholder="Search by title..." />
            </div>

            <div class="col-md-6">
                <label class="form-label">Location</label>
                <input type="text"
                       name="location"
                       value="@ViewData["CurrentLocation"]"
                       class="form-control"
                       placeholder="Search by location..." />
            </div>

            <div class="col-md-4">
                <label class="form-label">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>

                    @foreach (var category in new[] { "Safety", "Accessibility", "Maintenance", "Facilities", "Cleanliness", "IT/Wi-Fi", "Study Spaces" })
                    {
                        if (currentCategory == category)
                        {
                            <option value="@category" selected>@category</option>
                        }
                        else
                        {
                            <option value="@category">@category</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>

                    @foreach (var status in new[] { "Open", "Being Investigated", "Resolved", "No Action Required" })
                    {
                        if (currentStatus == status)
                        {
                            <option value="@status" selected>@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-campus w-100">
                    Apply Filters
                </button>
            </div>
        </div>
    </form>

    <div class="surface p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Location</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Reported</th>
                        <th>Upvotes</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var report in Model)
                        {
                            <tr>
                                <td class="fw-bold">@report.Title</td>
                                <td>@report.Location</td>
                                <td>@report.Category</td>
                                <td>
                                    <span class="badge @GetStatusClass(report.Status)">
                                        @report.Status
                                    </span>
                                </td>
                                <td>@report.Date_Reported.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="fw-bold">@report.Upvotes</td>
                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@report.Id"
                                       class="btn btn-sm btn-outline-info">
                                        Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <h5 class="mb-2">No reports found</h5>
                                <p class="mb-3">
                                    Try changing your filters or submit a new campus issue.
                                </p>

                                <a asp-action="Create" class="btn btn-campus">
                                    Submit New Report
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>