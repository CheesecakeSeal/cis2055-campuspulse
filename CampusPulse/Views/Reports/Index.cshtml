
@model IEnumerable<CampusPulse.Models.Report>

@{
    ViewData["Title"] = "Reports";
}

<div class="container mt-5">
    <h1 class="mb-4">Submitted Reports</h1>

    <form asp-action="Index" method="get" class="shadow-sm p-4 bg-light rounded mb-4">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-bold">Search Title</label>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                       class="form-control" placeholder="Title..." />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold">Location</label>
                <input type="text" name="location" value="@ViewData["CurrentLocation"]"
                       class="form-control" placeholder="Location..." />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-bold">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <option value="Safety">Safety</option>
                    <option value="Accessibility">Accessibility</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Safety">Safety</option>
                    <option value="Facilities">Facilities</option>
                    <option value="Cleanliness">Cleanliness</option>
                    <option value="IT/Wi-Fi">IT/Wi-Fi</option>
                    <option value="Accessibility">Accessibility</option>
                    <option value="Study Spaces">Study Spaces</option>
                    <option value="Maintenance">Maintenance</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Open">Open</option>
                    <option value="Being Investigated">Being Investigated</option>
                    <option value="Resolved">Resolved</option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-dark w-100 py-2">Apply Filters</button>
            </div>
        </div>
    </form>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Submit New Report</a>
    </div>

    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Title</th>
                <th>Location</th>
                <th>Category</th>
                <th>Status</th>
                <th>Reported</th>
                <th>Upvotes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var report in Model)
                {
                    <tr>
                        <td class="fw-bold">@report.Title</td>
                        <td>@report.Location</td>
                        <td>@report.Category</td>
                        <td>
                            @if (report.Status == "Resolved")
                            {
                                <span class="badge bg-success">Resolved</span>
                            }
                            else if (report.Status == "Being Investigated")
                            {
                                <span class="badge bg-warning text-dark">Investigating</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Open</span>
                            }
                        </td>
                        <td>@report.Date_Reported.ToString("dd MMM HH:mm")</td>
                        <td>@report.Upvotes</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm btn-outline-info">Details</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-5">
                        <i class="bi bi-search d-block fs-2 mb-2"></i>
                        No pulses found matching your filters.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>